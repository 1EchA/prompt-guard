# Prompt-Guard Configuration
# Copy this file to .env and fill in your values

# ── Upstream LLM API ────────────────────────────────────────
# The backend LLM API that prompt-guard forwards allowed requests to.
# Examples:
#   - Another container:    http://new-api:3000
#   - Host service (Mac):   http://host.docker.internal:3000
#   - Remote API:           https://api.your-llm.com
PROMPT_GUARD_UPSTREAM_URL=http://127.0.0.1:3000

# ── Guard mode ──────────────────────────────────────────────
# off    : pass-through, no scanning
# shadow : scan + DS review, log results but do NOT block (recommended for first run)
# block  : scan + DS review, block violations with HTTP 403
PROMPT_GUARD_MODE=shadow

# ── DeepSeek API ────────────────────────────────────────────
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Model name (e.g. deepseek-chat, deepseek-v4-flash)
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Dashboard ───────────────────────────────────────────────
# Access token for the web dashboard — change this!
DASHBOARD_TOKEN=change_me_to_random_string

# ── DeepSeek cost estimation (CNY per 1M tokens) ───────────
# Defaults match deepseek-v4-flash pricing; adjust for other models.
DS_PRICE_IN_PER_M=1
DS_PRICE_CACHED_PER_M=0.02
DS_PRICE_OUT_PER_M=2

# ── Optional: token-to-user resolution via DB ──────────────
# Not required. If you want user/group info in audit events,
# configure the DB connection inside channel_scan_config.json
# (db_host / db_user / db_pass / db_name + queries).
# No env var needed here.
