# Prompt-Guard Configuration
# Copy this file to .env and fill in your values

# Guard mode: off / shadow / block
PROMPT_GUARD_MODE=shadow

# DeepSeek API key for content review
# Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# DeepSeek model (default: deepseek-chat, or deepseek-v4-flash)
DEEPSEEK_MODEL=deepseek-v4-flash

# Dashboard access token (change this!)
DASHBOARD_TOKEN=change_me_to_random_string

# DeepSeek cost estimation (CNY per 1M tokens, deepseek-v4-flash pricing)
# Adjust if using a different model
DS_PRICE_IN_PER_M=1
DS_PRICE_CACHED_PER_M=0.02
DS_PRICE_OUT_PER_M=2

# Optional: MySQL/PostgreSQL for token-to-user resolution
# Leave empty to run without DB (user info will not be resolved)
# MYSQL_DSN=
# PG_DSN=
